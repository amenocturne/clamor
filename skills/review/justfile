default:
    @just --list

# Launch review server (pass flags after --)
launch *FLAGS:
    bun run src/server.ts -- {{FLAGS}}

dev:
    bun run src/server.ts

build:
    bun build src/frontend/main.ts --outdir dist --minify

test:
    bun test

check:
    bunx biome check .

fix:
    bunx biome check --write .

typecheck:
    bunx tsc --noEmit
