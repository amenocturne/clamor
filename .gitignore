# OS
.DS_Store

# Python bytecode (safe to ignore everywhere)
__pycache__/
*.pyc

# Hook-specific ignores
hooks/link-proxy/.venv/
hooks/link-proxy/.ruff_cache/
hooks/link-proxy/uv.lock
hooks/link-proxy/data/
hooks/link-proxy/domains.txt

# Pipeline-specific ignores
pipelines/workspace/.venv/
pipelines/workspace/.ruff_cache/
pipelines/workspace/uv.lock

# Save-conversation hook
hooks/save-conversation/.venv/
hooks/save-conversation/.ruff_cache/
hooks/save-conversation/uv.lock

# Skill virtual environments (created by uv run with PEP 723 scripts)
skills/**/.venv/

# Machine-specific installation registry
installations.yaml

# Rust build artifacts
tools/*/target/

# Temporary TODO files
TODO.md

# Claude Code local state
.claude/
