{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "TOKEN=$(jq -r .session_id); clamor set-state working --agent \"$CLAMOR_AGENT_ID\" --session-token \"$TOKEN\"",
          "timeout": 5
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "clamor set-state input --agent \"$CLAMOR_AGENT_ID\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "TOOL=$(jq -r .tool_name); clamor set-state working --agent \"$CLAMOR_AGENT_ID\" --tool \"$TOOL\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "TOOL=$(jq -r .tool_name); clamor set-state input --agent \"$CLAMOR_AGENT_ID\" --tool \"$TOOL\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "clamor set-state working --agent \"$CLAMOR_AGENT_ID\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "clamor set-state working --agent \"$CLAMOR_AGENT_ID\"",
          "timeout": 5
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "clamor set-state input --agent \"$CLAMOR_AGENT_ID\"",
          "timeout": 5
        }
      ]
    }
  ]
}
